TZ=Asia/Shanghai
NODE_ENV=production

NEXT_PUBLIC_APP_NAME=洄归生态客户管理与报价协同系统
NEXT_PUBLIC_API_BASE_URL=/api
APP_BASE_URL=https://crm.hui-health.com

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
MYSQL_PORT=3306

# 默认走 compose 内 mysql 服务；切换腾讯云数据库时把 DB_HOST 改成实例内网地址，
# 并通过 ./deploy/deploy.sh --skip-mysql 跳过本机 mysql 容器。
DB_HOST=mysql
DB_PORT=3306
DB_WAIT_TIMEOUT=180
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=huigui_crm
MYSQL_USER=huigui
MYSQL_PASSWORD=HuiguiDB2026
# 数据库密码包含特殊字符时，建议直接填写完整 DATABASE_URL。
DATABASE_URL=mysql://huigui:HuiguiDB2026@mysql:3306/huigui_crm

JWT_SECRET=replace-with-a-strong-secret

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Huigui@123

MYSQL_DATA_DIR=./storage/mysql
UPLOADS_DIR=./storage/uploads
LOCAL_UPLOAD_DIR=/app/storage/uploads

PDF_FONT_PATH=/usr/share/fonts/truetype/wqy/wqy-zenhei.ttc
CONTRACT_REMINDER_DAYS=7

COS_REGION=
COS_BUCKET=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_UPLOAD_PREFIX=uploads
COS_UPLOAD_DURATION_SECONDS=1800

WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_AES_KEY=
WECOM_BASE_URL=https://qyapi.weixin.qq.com
